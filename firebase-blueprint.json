{
  "entities": {
    "StoryCard": {
      "title": "Story Card",
      "description": "A definition for a game story card, including its rules, goals, and metadata.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the story card." },
        "intro": { "type": "string", "description": "Introductory text for the story." },
        "setupDescription": { "type": "string", "description": "A brief description of the setup changes." },
        "requiredExpansion": { "type": "string", "description": "The primary expansion required for this story." },
        "additionalRequirements": { "type": "array", "items": { "type": "string" }, "description": "List of additional expansions required." },
        "sourceUrl": { "type": "string", "description": "Link to the original source of the story card." },
        "isSolo": { "type": "boolean", "description": "Whether this is a solo story." },
        "isCoOp": { "type": "boolean", "description": "Whether this is a co-op story." },
        "isPvP": { "type": "boolean", "description": "Whether this is a PvP story." },
        "playerCount": { "type": "number", "description": "Recommended player count." },
        "maxPlayerCount": { "type": "number", "description": "Maximum player count." },
        "sortOrder": { "type": "number", "description": "Order for sorting in lists." },
        "rating": { "type": "number", "description": "User or community rating." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for filtering and categorization." },
        "goals": { "type": "array", "items": { "$ref": "StoryCardGoal" }, "description": "List of goals for the story." },
        "challengeOptions": { "type": "array", "items": { "$ref": "ChallengeOption" }, "description": "Optional challenges for the story." },
        "rules": { "type": "array", "items": { "type": "object" }, "description": "Functional rules associated with the story." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last updated timestamp." },
        "updatedBy": { "type": "string", "description": "User ID of the last editor." }
      },
      "required": ["title", "intro"]
    },
    "StoryCardGoal": {
      "title": "Story Card Goal",
      "description": "A specific goal within a story card.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["title", "description"]
    },
    "ChallengeOption": {
      "title": "Challenge Option",
      "description": "An optional challenge for a story.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" }
      },
      "required": ["id", "label"]
    },
    "SetupCard": {
      "title": "Setup Card",
      "description": "A definition for a base setup card.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "requiredExpansion": { "type": "string" },
        "mode": { "type": "string" },
        "rules": { "type": "array", "items": { "type": "object" } },
        "isCombinable": { "type": "boolean" },
        "sourceUrl": { "type": "string" }
      },
      "required": ["id", "label"]
    },
    "Location": {
      "title": "Location",
      "description": "A navigational space or planet in the game.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["planet", "space", "relay", "other"] },
        "systemId": { "type": "string" },
        "sector": { "type": "string" },
        "region": { "type": "string" }
      },
      "required": ["id", "label", "type", "systemId"]
    }
  },
  "firestore": {
    "/storyCards/{storyId}": {
      "schema": "StoryCard",
      "description": "Collection of story cards."
    },
    "/setupCards/{setupId}": {
      "schema": "SetupCard",
      "description": "Collection of setup cards."
    },
    "/locations/{locationId}": {
      "schema": "Location",
      "description": "Collection of game locations."
    }
  }
}
